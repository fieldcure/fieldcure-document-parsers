<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>
    <Version>2.0.1</Version>
    <AssemblyName>FieldCure.DocumentParsers</AssemblyName>
    <RootNamespace>FieldCure.DocumentParsers</RootNamespace>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <!-- NuGet Package Metadata -->
    <PackageId>FieldCure.DocumentParsers</PackageId>
    <Description>Document text extraction for DOCX, HWPX, XLSX, PPTX, HTML, and PDF. RAG-ready structured Markdown output with heading detection, tables, metadata (YAML front matter), footnotes, endnotes, comments, and headers/footers. Pure managed (no native binaries) — PDF text extraction via PdfPig.</Description>
    <Authors>Jong Hyun Kim</Authors>
    <Company>Fieldcure Co., Ltd.</Company>
    <Copyright>Copyright (c) 2026 Fieldcure Co., Ltd.</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/fieldcure/fieldcure-document-parsers</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>document;parser;docx;hwpx;xlsx;pptx;html;htm;pdf;text-extraction;rag;metadata;footnotes</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReleaseNotes>
      v2.0.1 — `ExtractionOptions` is no longer sealed so downstream parser packages (e.g. FieldCure.DocumentParsers.Audio) can subclass it. Adds `ExtractionOptions.SourceExtension` so callers can hint the source format and let parsers skip probing.
    </PackageReleaseNotes>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="icon.png" Pack="true" PackagePath="" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="DocumentParsers.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="DocumentFormat.OpenXml" Version="3.*" />
    <PackageReference Include="SmartReader" Version="*" />
    <PackageReference Include="ReverseMarkdown" Version="*" />
    <PackageReference Include="PdfPig" Version="0.1.*" />
  </ItemGroup>

</Project>
