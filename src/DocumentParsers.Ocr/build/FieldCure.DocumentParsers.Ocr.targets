<Project>
  <!-- Tesseract native DLLs — filenames are version-specific.
       When upgrading Tesseract, update both this file AND the csproj <ItemGroup>
       (e.g., tesseract50.dll -> tesseract53.dll, leptonica version may also change).

       See DocumentParsers.Ocr.csproj for the full rationale on why this uses
       "x64/" + targets instead of the runtimes/<rid>/native/ convention.
       TL;DR: PackAsTool consumers need the tools/<tfm>/<arch>/ layout, which
       runtimes/ does not provide.

       Why the output Link is always "x64\..." even on ARM64:
       The wrapper's SystemManager.GetPlatformName() (charlesw/tesseract) returns
       "x64" for any 64-bit process — IntPtr.Size only, no arch detection. So
       the wrapper looks for natives at <baseDir>\x64\tesseract50.dll on both
       win-x64 and win-arm64. The "x64\" output folder name is wrapper-driven,
       not arch-driven; we land the right-arch binaries there based on
       $(Platform) / $(RuntimeIdentifier).

       Library vs PackAsTool packing:
       For library consumers we pack ONE arch into the consumer's bin/x64/
       at build time (the host arch is known when they build). For PackAsTool
       consumers we pack BOTH arches into the tool nupkg because the same
       tool nupkg may be fetched and run by `dnx` on either x64 or ARM64,
       and the OCR runtime bootstrap (NativeLibraryBootstrap.cs) flips
       LibraryLoader.CustomSearchPath based on the actual process arch. -->

  <PropertyGroup>
    <_FieldCureOcrIsArm64>false</_FieldCureOcrIsArm64>
    <_FieldCureOcrIsArm64 Condition="'$(RuntimeIdentifier)' == 'win-arm64' Or '$(Platform)' == 'ARM64' Or '$(PlatformTarget)' == 'ARM64' Or '$(NETCoreSdkRuntimeIdentifier)' == 'win-arm64'">true</_FieldCureOcrIsArm64>
  </PropertyGroup>

  <!-- Library build (PackAsTool != true): copy ONE arch to output x64/ -->
  <ItemGroup Condition="'$(PackAsTool)' != 'true' And '$(_FieldCureOcrIsArm64)' != 'true'">
    <None Include="$(MSBuildThisFileDirectory)..\x64\leptonica-1.82.0.dll"
          CopyToOutputDirectory="PreserveNewest"
          Link="x64\leptonica-1.82.0.dll" />
    <None Include="$(MSBuildThisFileDirectory)..\x64\tesseract50.dll"
          CopyToOutputDirectory="PreserveNewest"
          Link="x64\tesseract50.dll" />
  </ItemGroup>

  <ItemGroup Condition="'$(PackAsTool)' != 'true' And '$(_FieldCureOcrIsArm64)' == 'true'">
    <None Include="$(MSBuildThisFileDirectory)..\arm64\leptonica-1.82.0.dll"
          CopyToOutputDirectory="PreserveNewest"
          Link="x64\leptonica-1.82.0.dll" />
    <None Include="$(MSBuildThisFileDirectory)..\arm64\tesseract50.dll"
          CopyToOutputDirectory="PreserveNewest"
          Link="x64\tesseract50.dll" />
  </ItemGroup>

  <!-- PackAsTool: pack BOTH arches into the tool nupkg.
         x64 binaries          -> tools/<tfm>/any/x64/           (wrapper default)
         arm64 binaries        -> tools/<tfm>/any/arm64-platform/x64/
       NativeLibraryBootstrap in DocumentParsers.Ocr flips
       LibraryLoader.CustomSearchPath to <basedir>/arm64-platform/ on ARM64
       processes so the wrapper resolves the second tree. -->
  <ItemGroup Condition="'$(PackAsTool)' == 'true'">
    <None Include="$(MSBuildThisFileDirectory)..\x64\leptonica-1.82.0.dll"
          Pack="true"
          PackagePath="tools/$(TargetFramework)/any/x64/"
          Visible="false" />
    <None Include="$(MSBuildThisFileDirectory)..\x64\tesseract50.dll"
          Pack="true"
          PackagePath="tools/$(TargetFramework)/any/x64/"
          Visible="false" />
    <None Include="$(MSBuildThisFileDirectory)..\arm64\leptonica-1.82.0.dll"
          Pack="true"
          PackagePath="tools/$(TargetFramework)/any/arm64-platform/x64/"
          Visible="false" />
    <None Include="$(MSBuildThisFileDirectory)..\arm64\tesseract50.dll"
          Pack="true"
          PackagePath="tools/$(TargetFramework)/any/arm64-platform/x64/"
          Visible="false" />
  </ItemGroup>
</Project>
